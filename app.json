{
  "expo": {
    "name": "VisionWalkHelper",
    "slug": "VisionWalkHelper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "visionwalkhelper",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.capstone.visionwalkhelper",
      "infoPlist": {
        // 1) Make sure the module can read your app key at runtime:
        "KAKAO_APP_KEY": "kakao0d500c85e8e9b46cc532ec3111fb84bb",

        // 2) Register Kakao's custom URL scheme so it can callback:
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "kakao0d500c85e8e9b46cc532ec3111fb84bb"
            ]
          }
        ],

        // 3) Whitelist Kakao-auth schemes so iOS can open them:
        "LSApplicationQueriesSchemes": [
          "kakaokompassauth",
          "kakaolink",
          "kakaoauth",
          "kakaotalk"
        ],

        // (Optional) Any other permissions you already had:
        "NSBluetoothAlwaysUsageDescription": "This app needs access to Bluetooth to connect to devices.",
        "NSBluetoothPeripheralUsageDescription": "This app needs access to Bluetooth to connect to peripheral devices.",
        "NSLocationWhenInUseUsageDescription": "앱이 사용 중일 때 위치 정보를 사용합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "앱이 백그라운드에서도 위치 정보를 사용합니다.",
        "NSLocationTemporaryUsageDescriptionDictionary": {
          "common-purpose": "정확한 위치를 사용하기 위해 필요합니다."
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.capstone.visionwalkhelper",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "react-native-permissions",
        {
          "permissions": {
            "ios": [
              "LOCATION_WHEN_IN_USE",
              "LOCATION_ALWAYS"
            ]
          }
        }
      ],
      "expo-build-properties",
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "kakao0d500c85e8e9b46cc532ec3111fb84bb",
          "kakaoRedirectURL": "kakao0d500c85e8e9b46cc532ec3111fb84bb://oauth"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}